{
  "name": "wan-music",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend & npm run dev --workspace=backend",
    "dev:api": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "test": "npm run test --workspace=backend",
    "test:watch": "npm run test:watch --workspace=backend",
    "test:ui": "npm run test:ui --workspace=frontend",
    "test:ui:headed": "npm run test:ui:headed --workspace=frontend",
    "test:ui:debug": "npm run test:ui:debug --workspace=frontend",
    "test:install": "npm run test:install --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^10.0.0"
  }
}
