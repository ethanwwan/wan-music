{
  "name": "wan-music",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:api\"",
    "dev:api": "cd backend && python3 main.py",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "test": "cd tests/backend && python3 -m pytest",
    "test:quick": "cd tests/backend && python3 test_quick_verify.py",
    "test:ui": "cd frontend && npm run test:ui",
    "test:ui:headed": "cd frontend && npm run test:ui:headed",
    "test:ui:debug": "cd frontend && npm run test:ui:debug",
    "test:install": "cd frontend && npm run test:install",
    "test:download": "npx playwright test tests/system/test-download-module.mjs",
    "test:download:headed": "npx playwright test tests/system/test-download-module.mjs --headed",
    "test:all": "npm run test && npm run test:download"
  },
  "devDependencies": {
    "concurrently": "^10.0.0"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0"
  }
}
