# ============================================================
# Wan Music - 端口与环境变量配置示例
# 复制为 .env 并填入实际值：cp .env.example .env
# ============================================================

# ---------- Docker 部署（生产环境）----------

# 镜像名
# - 本地构建：wan-music:latest
# - 拉取远程：ghcr.io/<你的用户名>/wan-music:v1.0.0
WAN_MUSIC_IMAGE=wan-music:latest

# 容器内端口（Flask 监听的端口）
# 一般不需要改，除非与其他服务冲突
CONTAINER_PORT=5002

# 主机端口（暴露给外部访问的端口）
# 浏览器访问 http://localhost:8080
# 如果设置为 80，需要 root 权限
HOST_PORT=5002

# 时区
TZ=Asia/Shanghai

# ---------- 开发环境（npm run dev）----------

# Vite dev server 端口
VITE_PORT=5175

# 后端 Flask 地址（vite proxy 转发目标）
# 仅开发环境使用；生产环境走同源或 VITE_API_BASE
VITE_API_PROXY_TARGET=http://localhost:5002

# 后端 Flask 端口
BACKEND_PORT=5002

# ---------- 生产环境 API 基础路径（可选）----------
# 仅当需要跨域/反向代理时设置
# 默认：同源（推荐）
# 跨域示例：VITE_API_BASE=https://api.example.com
# 留空或不设置 = 同源，相对路径 /api/*
VITE_API_BASE=
