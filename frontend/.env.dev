# ============================================================
# 开发环境配置（npm run dev 加载）
# ============================================================

# Vite dev server 端口
VITE_PORT=5175

# 后端 Flask 地址（vite proxy 转发目标）
VITE_API_PROXY_TARGET=http://localhost:5002

# 后端 Flask 端口（启动时检查端口冲突）
BACKEND_PORT=5002
