# ============================================================
# 开发环境配置（npm run dev / dev:full 加载）
# ============================================================

# Vite dev server 端口
VITE_PORT=5175

# 后端 Flask 端口（dev:api 启动时读取）
# vite.config.js 也会读这个作为 proxy 目标
BACKEND_PORT=5005

# 后端 Flask 完整地址（vite proxy 转发目标）
# 可选：如果不设，会用 http://localhost:${BACKEND_PORT}
VITE_API_PROXY_TARGET=http://localhost:5005
