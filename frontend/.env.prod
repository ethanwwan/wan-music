# ============================================================
# 生产环境配置（npm run build 加载）
# 打包到 dist/ 后，运行时可通过环境变量覆盖
# ============================================================

# Vite build preview 端口（仅 npm run preview 用，Docker 中不使用）
VITE_PORT=5175

# 后端 API 基础路径
# - 留空或设为 ''：使用相对路径（推荐，同源部署）
# - 设为 'http://api.example.com'：跨域部署
VITE_API_BASE=

# 后端 Flask 端口（容器内监听端口）
BACKEND_PORT=5002
