{
  "name": "@wan-music/frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "dev:lan": "vite --mode dev --host 0.0.0.0 --port 5173",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "dev:api": "cd .. && python3 backend/main.py",
    "build": "vite build --mode prod",
    "build:dev": "vite build --mode dev",
    "preview": "vite preview --mode prod",
    "preview:dev": "vite preview --mode dev",
    "preview:full": "concurrently \"npm run preview\" \"npm run preview:api\"",
    "preview:api": "cd .. && python3 backend/main.py",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "test:install": "playwright install --with-deps",
    "test:backend": "cd .. && python3 -m pytest tests/backend",
    "test:quick": "cd .. && python3 tests/backend/test_quick_verify.py",
    "test:download": "playwright test tests/system/test-download-module.mjs",
    "test:download:headed": "playwright test tests/system/test-download-module.mjs --headed",
    "test:all": "npm run test:backend && npm run test:download"
  },
  "dependencies": {
    "@vueuse/core": "^10.7.0",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.12.2",
    "browser-id3-writer": "^6.3.1",
    "jszip": "^3.10.1",
    "pinia": "^2.1.7",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "vite": "^5.4.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-compression2": "^2.2.1",
    "concurrently": "^10.0.0"
  }
}
